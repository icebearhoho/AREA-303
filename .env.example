# AREA 303 — LLM backend config. Copy to `.env` (gitignored) and fill in.
# Primary backend is OpenAI. Ollama is an optional local fallback.

# openai | ollama
LLM_BACKEND=openai

# response cache (1=on) and max concurrent requests for batch evals
LLM_CACHE=1
LLM_WORKERS=8

# --- OpenAI (primary) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Ollama (optional local fallback; set LLM_BACKEND=ollama to use) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=bge-m3
