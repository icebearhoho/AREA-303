# =====================================================================
# AREA 303 — Backend environment template.
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =====================================================================

# ---------- App ----------
APP_NAME="AREA-303 API"
APP_ENV=development           # development | staging | production | test
DEBUG=true
API_V1_PREFIX=/api/v1

# Comma-separated origins for CORS. Add the frontend dev server here.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------- Postgres ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=area303
POSTGRES_PASSWORD=area303
POSTGRES_DB=area303
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ---------- Auth / JWT ----------
# Override in production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---------- Observability ----------
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
# SENTRY_DSN=

# ---------- Pagination ----------
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
