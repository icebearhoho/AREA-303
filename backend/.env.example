# =====================================================================
# AREA 303 — Backend environment template.
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =====================================================================

# ---------- App ----------
APP_NAME="AREA-303 API"
APP_ENV=development           # development | staging | production | test
DEBUG=true
API_V1_PREFIX=/api/v1

# Comma-separated origins for CORS. Add the frontend dev server here.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------- Postgres ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=area303
POSTGRES_PASSWORD=area303
POSTGRES_DB=area303
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ---------- Auth / JWT ----------
# Override in production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---------- Observability ----------
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
# SENTRY_DSN=

# ---------- Pagination ----------
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ---------- GenAI ----------
# Demo mode — when true, all GenAI endpoints return pre-generated fixtures.
# This is the safety net for quota exhaustion and offline demos.
DEMO_MODE=true

# LLM provider — gemini | openai | mock.  mock = no real calls.
LLM_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# LLM response cache TTL (seconds).
LLM_CACHE_TTL_SECONDS=600

# Rate limit per IP per minute on /api/v1/* GenAI routes.
RATE_LIMIT_PER_MINUTE=30

# ---------- RAG / Vector store ----------
PINECONE_API_KEY=
PINECONE_INDEX=area303-tiki-catalog
PINECONE_ENVIRONMENT=
VECTOR_BACKEND=memory   # pinecone | faiss | memory
EMBEDDING_MODEL=text-embedding-3-small

# ---------- SSE ----------
SSE_HEARTBEAT_SECONDS=15
