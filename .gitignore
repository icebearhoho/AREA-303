# AREA 303 — .gitignore
# dataset/ raw + processed data is large (~11GB) and reproducible from
# download_*.py -> clean_pipeline*.py. Never commit the data itself —
# just the small docs (README.md, _SOURCE.txt, AI_BRIEF.md, etc.).

# --- Heavy/reproducible data files under dataset/ ---
dataset/**/*.parquet
dataset/**/*.csv
dataset/**/*.jsonl
dataset/**/*.xlsx
dataset/**/*.xls
dataset/**/*.png
dataset/**/code_repo/
**/.cache/

# --- Secrets (never commit) ---
kaggle.json
.env
*.key

# --- Python ---
__pycache__/
*.py[cod]
.venv/

# --- Feature-folder local data + large artifacts (Ollama modeling) ---
# keep code, README, small configs & figures; ignore data copies + big indexes
*/data/*.parquet
*/data/*.csv
*/outputs/*.parquet
*/outputs/*.csv
*/models/*.npy
*/models/*.npz
*/models/*.faiss
*/models/*.pkl.big

# --- Office lock files ---
.~lock.*#

# --- Local-only working files (kept on this machine, not pushed to GitHub) ---
# code/ is data-processing's local pipeline; track only the modeling repro scripts.
code/*
!code/download_clean_ideas.py
!code/build_dashboard.py
!code/ab_prompts.py
report/*
!report/CONTRIBUTING.md
HANDOFF.md
# generated by code/build_dashboard.py (self-contained, 300KB+)
dashboard.html
