# =====================================================================
# Root-level env template. Variables consumed by docker-compose.yml.
# Copy to `.env` at the repo root. Never commit `.env`.
# =====================================================================

# Ports exposed on the host
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=8000

# Postgres credentials used by docker compose + backend
POSTGRES_USER=area303
POSTGRES_PASSWORD=area303
POSTGRES_DB=area303

# The backend reads its full config from backend/.env (see backend/.env.example).
# docker-compose passes those values through to the backend container.

# =====================================================================
# LLM modeling layer (ideas #01-#05) — read by common/llm_client.py
# Primary backend is OpenAI; Ollama is an optional local fallback.
# =====================================================================

# openai | ollama
LLM_BACKEND=openai
LLM_CACHE=1
LLM_WORKERS=8

# --- OpenAI (primary) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Ollama (optional local fallback; set LLM_BACKEND=ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=bge-m3
